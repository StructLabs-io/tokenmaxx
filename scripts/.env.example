# Tokenmaxx Pipeline Scripts — Environment Variables
#
# Copy to .env.local or set in shell / crontab before running scripts.
# NEVER commit actual values to git.

# Supabase connection (required by all scripts)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Capture scripts (server-capture.js, local-capture.js)
TOKENMAXX_WORKSPACE_ID=your-workspace-uuid
TOKENMAXX_USER_SLUG=ben-macbook

# Optional overrides
# CODEX_SESSIONS_DIR=/Users/benauknowra/.codex/sessions
# TOKENMAXX_LOCAL_STATE_FILE=~/.config/tokenmaxx/local-state.json
# TOKENMAXX_SERVER_STATE_FILE=/home/openclaw/.config/tokenmaxx/server-state.json
